{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "/Users/andreasdator/feedpilot-ai/feedpilot/.claude/hooks/require-ticket-in-commit.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(*.py)|Write(*.py)",
        "hooks": [{ "type": "command", "command": "cd /Users/andreasdator/feedpilot-ai/feedpilot && venv/bin/python -m mypy $file --ignore-missing-imports --no-error-summary 2>&1 | tail -10" }]
      },
      {
        "matcher": "Edit(*.tsx)|Write(*.tsx)|Edit(*.ts)|Write(*.ts)",
        "hooks": [{ "type": "command", "command": "cd /Users/andreasdator/feedpilot-ai/feedpilot/frontend && npx tsc --noEmit 2>&1 | tail -10" }]
      }
    ]
  }
}