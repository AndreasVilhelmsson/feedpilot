# FeedPilot — Backend environment variables
# Kopiera till backend/.env och fyll i riktiga värden.
# Fältnamnen matchar exakt Settings-modellen i backend/app/core/config.py.

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Databas
DATABASE_URL=postgresql://feedpilot:feedpilot@postgres:5432/feedpilot

# Redis (separata fält — inte REDIS_URL)
REDIS_HOST=redis
REDIS_PORT=6379
